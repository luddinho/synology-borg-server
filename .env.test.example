# Test environment example
TZ=Europe/Berlin

# Host SSH port exposed by docker-compose
SSH_HOST_PORT=2223

# SSH daemon log detail level (QUIET,FATAL,ERROR,INFO,VERBOSE,DEBUG,DEBUG1,DEBUG2,DEBUG3)
SSH_LOG_LEVEL=VERBOSE

# Host paths (test)
SSH_CONFIG_DIR=/volume1/borg-backups-test/config/ssh
AUTHORIZED_KEYS_FILE=/volume1/borg-backups-test/config/authorized_keys
BORG_REPOS_DIR=/volume1/borg-backups-test/repos

# Dedicated test backup service user (non-admin)
BORG_USER=borgtest
BORG_UID=1071
BORG_GID=100

# Optional: blocklist.de feed based IP bans inside the container firewall
BLOCKLIST_ENABLED=false
# Allowed values: all, ssh, mail, apache, imap, ftp, sip, bots, strongips, ircbot, bruteforcelogin
BLOCKLIST_TYPE=ssh
# Optional multi-selection (comma/semicolon/space separated), e.g.: ssh,bruteforcelogin
# If set, this is used instead of BLOCKLIST_TYPE.
BLOCKLIST_TYPES=
# Optional URL override. If set, this overrides BLOCKLIST_TYPE/BLOCKLIST_TYPES.
BLOCKLIST_URL=
BLOCKLIST_CRON=*/10 * * * *
BLOCKLIST_TARGET_PORTS=22
BLOCKLIST_SET_NAME=blocklist_de
BLOCKLIST_CHAIN_NAME=BLOCKLIST_INPUT
